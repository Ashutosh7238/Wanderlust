<% layout("../layouts/boilerplate") %>

<div class="row mt-3">
    <h1 class="col-6 offset-3">Sign Up</h1>
    <div class="col-6 offset-3">
        <form method="post" action="/signup" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input type="text" name="username" placeholder="Enter username" id="username" class="form-control" required>
                <div class="invalid-feedback">Write Valid username</div>
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" name="email" placeholder="Enter Email" id="email" class="form-control" required>
                <div class="invalid-feedback">Write Valid email</div>
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input type="password" name="password" placeholder="Enter Password" id="password" class="form-control" required>
                <div class="invalid-feedback">Write Valid password</div>
            </div>

            <button class="btn btn-success">Submit</button>
        </form>
    </div>
</div>